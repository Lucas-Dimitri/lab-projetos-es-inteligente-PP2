# LLM provider: currently supported: "ollama"
UNIBOT_LLM_PROVIDER=ollama

# Ollama model to use for main agent responses
# Run "ollama pull qwen2.5" first (recommended: better Portuguese + tool use)
# Alternatives: llama3.1, mistral
UNIBOT_MODEL_ID=qwen2.5

# Ollama model for memory extraction (can be the same or a smaller model)
UNIBOT_MEMORY_MODEL_ID=qwen2.5

# Ollama server URL (default: local)
UNIBOT_OLLAMA_HOST=http://localhost:11434

# Embedding model (local FastEmbed, no API key needed, downloads on first run ~120MB)
UNIBOT_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# RAG retrieval: number of document chunks to retrieve per query
UNIBOT_NUM_RETRIEVED_DOCS=5

# RAG chunking: token size of each chunk
UNIBOT_CHUNK_SIZE=500

# Paths (relative to project root)
UNIBOT_DOCS_DIR=docs
UNIBOT_VECTOR_STORE_DIR=vector_store
UNIBOT_DATA_DIR=data
